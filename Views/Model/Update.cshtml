@using aspnet.Models.ViewModels
@model CarModelUpdateVM

<form asp-action="Update" method="post">
    <input asp-for="Id" type="hidden" />
    <input asp-for="Name" />
    <span asp-validation-for="Name"></span>
    <input asp-for="DailyPrice" />
    <span asp-validation-for="DailyPrice"></span>
    <input asp-for="NbSeats" />
    <span asp-validation-for="NbSeats"></span>
    <input asp-for="FuelType" />
    <span asp-validation-for="FuelType"></span>
    <input asp-for="CarBrand" />
    <span asp-validation-for="CarBrand"></span>
    <button type="submit">Update</button>
</form>