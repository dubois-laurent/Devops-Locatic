@model IEnumerable<CarCustomer>

<h2>Clients</h2>
<a asp-action="Create" class="btn btn-primary mb-3">Ajouter un client</a>

<ul class="list-group">
    @foreach (CarCustomer customer in Model)
    {
        <li class="list-group-item d-flex justify-content-between align-items-center">
            @customer.Name &mdash; @customer.Email &mdash; @customer.PhoneNumber
            <span>
                <a asp-action="Update" asp-route-id="@customer.Id" class="btn btn-sm btn-warning">Modifier</a>
                <a asp-action="Delete" asp-route-id="@customer.Id" class="btn btn-sm btn-danger">Supprimer</a>
            </span>
        </li>
    }
</ul>