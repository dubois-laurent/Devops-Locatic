@model IEnumerable<Car>

<h2>Voitures</h2>
<a asp-action="Create" class="btn btn-primary mb-3">Ajouter une voiture</a>

<ul class="list-group">
    @foreach (Car car in Model)
    {
        <li class="list-group-item d-flex justify-content-between align-items-center">
            @car.PlateNumber &mdash; @car.Brand @car.Model
            <span>
                <a asp-action="Update" asp-route-id="@car.Id" class="btn btn-sm btn-warning">Modifier</a>
                <a asp-action="Delete" asp-route-id="@car.Id" class="btn btn-sm btn-danger">Supprimer</a>
            </span>
        </li>
    }
</ul>